{
    // Point the Microsoft C/C++ IntelliSense engine at the compile_commands.json
    // generated by CMake during `make configure` (or `make`).
    // This gives IntelliSense the exact same include paths, defines, and flags
    // that the compiler uses — including all Qt framework headers.
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/debug/compile_commands.json",

    // Use the compile_commands.json as the configuration provider (overrides
    // the built-in tag-parser guessing).
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

    // Tell the Qt Extension where Qt is installed on this machine.
    // Adjust if your Qt installation path differs.
    "qt.defaultQtInstallationPath": "${env:HOME}/Qt",

    // Exclude build artefacts from the VS Code file explorer and search.
    "files.exclude": {
        "**/build": true,
        "**/__pycache__": true
    },
    "search.exclude": {
        "**/build": true
    }
}
